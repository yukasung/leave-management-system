generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  password      String?
  avatarUrl     String?
  phone         String?
  isProbation   Boolean  @default(false)
  departmentId  String?
  department    Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])
  managedDepartments Department[] @relation("DepartmentManager")
  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[]
  approvals     Approval[]
  auditLogs         AuditLog[]
  leaveAuditChanges LeaveAuditLog[] @relation("LeaveAuditChangedBy")
  notifications     Notification[]
  employee      Employee?
  createdAt     DateTime @default(now())
}

model Department {
  id        String     @id @default(uuid())
  name      String     @unique
  managerId String?
  manager   User?      @relation("DepartmentManager", fields: [managerId], references: [id])
  users     User[]     @relation("DepartmentMembers")
  employees Employee[]
  positions Position[]
  createdAt DateTime   @default(now())

  @@index([name])
}

model Position {
  id           String      @id @default(uuid())
  name         String      @unique
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  createdAt    DateTime    @default(now())

  @@index([name])
}

model LeaveType {
  id                   String  @id @default(uuid())
  name                 String  @unique
  maxDaysPerYear       Float?
  maxDaysPerRequest    Float?
  requiresAttachment   Boolean @default(false)
  deductFromBalance    Boolean @default(true)
  allowDuringProbation Boolean @default(true)
  leaveRequests        LeaveRequest[]
  leaveBalances        LeaveBalance[]
}

model LeaveBalance {
  id          String   @id @default(uuid())
  userId      String
  leaveTypeId String
  year        Int
  totalDays   Float
  usedDays    Float    @default(0)

  user        User     @relation(fields: [userId], references: [id])
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([userId, leaveTypeId, year])
}

model LeaveRequest {
  id          String     @id @default(uuid())
  userId      String
  leaveTypeId String
  leaveStartDateTime DateTime
  leaveEndDateTime   DateTime
  totalDays          Float
  reason      String?
  documentUrl String?
  status      LeaveStatus @default(DRAFT)
  approvals      Approval[]
  leaveAuditLogs LeaveAuditLog[]
  createdAt      DateTime @default(now())

  user        User       @relation(fields: [userId], references: [id])
  leaveType   LeaveType  @relation(fields: [leaveTypeId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Approval {
  id            String @id @default(uuid())
  leaveRequestId String
  approverId    String
  level         Int
  status        ApprovalStatus @default(PENDING)
  approvedAt    DateTime?

  leaveRequest  LeaveRequest @relation(fields: [leaveRequestId], references: [id])
  approver      User @relation(fields: [approverId], references: [id])
}

enum LeaveStatus {
  DRAFT
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  CANCEL_REQUESTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  action      String
  entityType  String
  entityId    String
  description String?
  createdAt   DateTime @default(now())

  user        User @relation(fields: [userId], references: [id])
}

model Employee {
  id           String      @id @default(uuid())
  employeeCode String      @unique
  firstName    String
  lastName     String
  email        String      @unique
  phone        String?
  avatarUrl    String?

  // 1:1 link to User account (optional — employee may not have a login yet)
  userId       String?     @unique
  user         User?       @relation(fields: [userId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  position     String
  positionId   String?
  positionRef  Position?   @relation(fields: [positionId], references: [id])

  isAdmin      Boolean     @default(false)
  isManager    Boolean     @default(false)

  // Many-to-many: approvers assigned to this employee
  approvers    Employee[]  @relation("EmployeeApprovers")
  approvedFor  Employee[]  @relation("EmployeeApprovers")

  // Direct supervisor — references another Employee (self-relation)
  managerId    String?
  manager      Employee?   @relation("EmployeeReportsTo", fields: [managerId], references: [id])
  subordinates Employee[]  @relation("EmployeeReportsTo")

  isActive     Boolean  @default(true)
  isProbation  Boolean  @default(true)

  createdAt    DateTime @default(now())

  @@index([departmentId])
  @@index([managerId])
  @@index([userId])
}

model LeaveAuditLog {
  id           String   @id @default(uuid())
  leaveId      String
  changedBy    String
  fieldChanged String
  oldValue     String?
  newValue     String?
  timestamp    DateTime @default(now())

  leave         LeaveRequest @relation(fields: [leaveId], references: [id])
  changedByUser User         @relation("LeaveAuditChangedBy", fields: [changedBy], references: [id])

  @@index([leaveId])
  @@index([changedBy])
  @@map("leave_audit_logs")
}

enum HolidaySource {
  BOT
  MANUAL
}

model CompanyHoliday {
  id        String        @id @default(uuid())
  date      DateTime      @db.Date
  name      String
  year      Int
  source    HolidaySource @default(MANUAL)
  createdAt DateTime      @default(now())

  @@unique([date])
  @@index([year])
  @@map("company_holidays")
}